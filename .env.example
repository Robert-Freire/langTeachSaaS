# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.
# Used by docker-compose for local development.

# SQL Server SA password — used by the sqlserver and api containers.
# Source: 1Password, item "LangTeach Docker SA"
SA_PASSWORD=

# Auth0 tenant — used by the api container to validate JWTs.
# Same domain/audience as frontend/.env.local.
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://api.langteach.io
