# Copy this file to .env.qa and fill in the values.
# .env.qa is gitignored — never commit it.
#
# Used with: docker compose -f docker-compose.qa.yml --env-file .env.qa up -d --build
#
# One-time setup:
#   1. Create an Auth0 user for the QA agent (see .claude/skills/teacher-qa/SKILL.md)
#   2. Fill in TEACHER_QA_* fields below
#   3. Install playwright deps: cd .claude/skills/teacher-qa/playwright && npm ci && npx playwright install chromium

# --- SQL Server ---
# Source: 1Password, item "LangTeach Docker SA"
SA_PASSWORD=

# --- Auth0 (backend JWT validation + frontend) ---
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://api.langteach.io
# SPA client ID for the frontend Auth0 provider
VITE_AUTH0_CLIENT_ID=your-spa-client-id

# --- Claude API ---
CLAUDE_API_KEY=

# --- Teacher QA dedicated Auth0 account ---
# Created once in Auth0 dashboard — separate from e2e test user so QA data persists.
# Email format suggestion: teacher-qa@langteach.test (or any real email you control)
TEACHER_QA_EMAIL=teacher-qa@example.com
TEACHER_QA_PASSWORD=
# Auth0 user ID — find in Auth0 dashboard under Users, format: auth0|xxxxxxxxxxxxxxxxxxxxxxxx
# Reserved for future direct API seeding (bypassing the browser login for data setup).
# Not read by the current Playwright scripts — they authenticate via the browser login flow.
TEACHER_QA_AUTH0_USER_ID=auth0|
