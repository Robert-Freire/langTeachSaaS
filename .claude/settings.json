{
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(*)",
      "WebSearch(*)",
      "WebFetch(*)",
      "NotebookEdit(*)",
      "Write(path:C:/ws/PersonalOS/03_Workspace/langTeachSaaS/**)",
      "Write(path:/c/ws/PersonalOS/03_Workspace/langTeachSaaS/**)",
      "Edit(path:C:/ws/PersonalOS/03_Workspace/langTeachSaaS/**)",
      "Edit(path:/c/ws/PersonalOS/03_Workspace/langTeachSaaS/**)",
      "mcp__github__*"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/worktree-setup.sh",
            "timeout": 120000
          }
        ]
      }
    ]
  }
}
