{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["items"],
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["word", "definition"],
        "additionalProperties": false,
        "properties": {
          "word": { "type": "string" },
          "definition": { "type": "string" },
          "exampleSentence": { "type": "string" }
        }
      }
    }
  }
}
