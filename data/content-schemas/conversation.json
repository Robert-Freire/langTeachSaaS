{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["scenarios"],
  "additionalProperties": false,
  "properties": {
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["setup", "roleA", "roleB", "roleAPhrases", "roleBPhrases"],
        "additionalProperties": false,
        "properties": {
          "setup": { "type": "string" },
          "roleA": { "type": "string" },
          "roleB": { "type": "string" },
          "roleAPhrases": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "roleBPhrases": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "keyPhrases": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
