{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["title", "explanation", "examples", "commonMistakes"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string" },
    "explanation": { "type": "string" },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sentence"],
        "additionalProperties": false,
        "properties": {
          "sentence": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "commonMistakes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
