{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "anyOf": [
    { "required": ["fillInBlank"] },
    { "required": ["multipleChoice"] },
    { "required": ["matching"] }
  ],
  "properties": {
    "fillInBlank": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sentence", "answer"],
        "additionalProperties": false,
        "properties": {
          "sentence": { "type": "string" },
          "answer": { "type": "string" },
          "hint": { "type": "string" },
          "explanation": { "type": "string" },
          "stage": { "type": "string", "enum": ["controlled", "meaningful", "guided_free"] }
        }
      }
    },
    "multipleChoice": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["question", "options", "answer"],
        "additionalProperties": false,
        "properties": {
          "question": { "type": "string" },
          "options": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string" }
          },
          "answer": { "type": "string" },
          "explanation": { "type": "string" },
          "stage": { "type": "string", "enum": ["controlled", "meaningful", "guided_free"] }
        }
      }
    },
    "matching": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["left", "right"],
        "additionalProperties": false,
        "properties": {
          "left": { "type": "string" },
          "right": { "type": "string" },
          "explanation": { "type": "string" },
          "stage": { "type": "string", "enum": ["controlled", "meaningful", "guided_free"] }
        }
      }
    }
  }
}
