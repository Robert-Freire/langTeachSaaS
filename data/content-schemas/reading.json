{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["passage", "comprehensionQuestions", "vocabularyHighlights"],
  "additionalProperties": false,
  "properties": {
    "passage": { "type": "string" },
    "comprehensionQuestions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["question", "answer", "type"],
        "additionalProperties": false,
        "properties": {
          "question": { "type": "string" },
          "answer": { "type": "string" },
          "type": { "type": "string" }
        }
      }
    },
    "vocabularyHighlights": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["word", "definition"],
        "additionalProperties": false,
        "properties": {
          "word": { "type": "string" },
          "definition": { "type": "string" }
        }
      }
    }
  }
}
