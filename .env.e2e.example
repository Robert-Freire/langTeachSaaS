# Copy this file to .env.e2e and fill in the values.
# .env.e2e is gitignored — never commit it.
#
# Used with: docker compose -f docker-compose.e2e.yml --env-file .env.e2e up --build

# --- SQL Server ---
# Source: 1Password, item "LangTeach Docker SA"
SA_PASSWORD=

# --- Auth0 (backend JWT validation + frontend) ---
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://api.langteach.io
# SPA client ID for the frontend Auth0 provider
VITE_AUTH0_CLIENT_ID=your-spa-client-id

# --- Claude API ---
CLAUDE_API_KEY=sk-ant-

# --- E2E test account (must exist in Auth0) ---
E2E_TEST_EMAIL=test-teacher@example.com
E2E_TEST_PASSWORD=your-test-password
# Auth0 user ID for the test account (used by db-helper.ts for direct SQL cleanup)
# Find it in Auth0 dashboard under Users — format: auth0|xxxxxxxxxxxxxxxxxxxxxxxx
E2E_TEST_AUTH0_USER_ID=auth0|
